// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// Game Management
// ============================================

model Game {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "Valorant", "League of Legends"
  slug        String   @unique // e.g., "valorant", "league-of-legends"
  icon        String? // URL to game icon/logo
  description String?  @db.Text
  active      Boolean  @default(true) // Can be toggled off to hide games
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tournaments Tournament[]
  teams       Team[]

  @@index([slug])
  @@index([active])
}

// ============================================
// User Management
// ============================================

enum UserRole {
  ADMIN
  ORGANIZER
  PLAYER
  SPECTATOR
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  username      String?   @unique
  password      String? // null for OAuth users
  avatar        String?
  role          UserRole  @default(PLAYER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts             Account[]
  sessions             Session[]
  ownedTeams           Team[]           @relation("TeamOwner")
  teamMemberships      TeamMember[]
  organizedTournaments Tournament[]     @relation("TournamentOrganizer")
  notifications        Notification[]
  sentMatchResults     Match[]          @relation("MatchResultSubmitter")
  receivedInvitations  TeamInvitation[] @relation("TeamInvitationUser")
  sentInvitations      TeamInvitation[] @relation("TeamInvitationInviter")

  @@index([email])
  @@index([username])
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Team Management
// ============================================

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  tag         String? // Team tag/abbreviation (e.g., "FNC", "G2")
  logo        String? // URL to team logo
  description String?  @db.Text
  gameId      String // Reference to Game model
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  game          Game                     @relation(fields: [gameId], references: [id])
  owner         User                     @relation("TeamOwner", fields: [ownerId], references: [id])
  members       TeamMember[]
  invitations   TeamInvitation[]
  registrations TournamentRegistration[]
  homeMatches   Match[]                  @relation("HomeTeam")
  awayMatches   Match[]                  @relation("AwayTeam")
  wonMatches    Match[]                  @relation("MatchWinner")

  @@index([ownerId])
  @@index([gameId])
}

enum TeamRole {
  CAPTAIN
  PLAYER
  SUBSTITUTE
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(PLAYER)
  joinedAt DateTime @default(now())

  // Relations
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

model TeamInvitation {
  id        String           @id @default(cuid())
  teamId    String
  email     String // Can invite by email
  userId    String? // Links to user if they have account
  role      TeamRole         @default(PLAYER)
  status    InvitationStatus @default(PENDING)
  invitedBy String // User who sent the invitation
  expiresAt DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  team    Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user    User? @relation("TeamInvitationUser", fields: [userId], references: [id], onDelete: Cascade)
  inviter User  @relation("TeamInvitationInviter", fields: [invitedBy], references: [id])

  @@index([teamId])
  @@index([userId])
  @@index([email])
  @@index([status])
}

// ============================================
// Tournament Management
// ============================================

enum TournamentFormat {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  ROUND_ROBIN
  SWISS
}

enum TournamentStatus {
  DRAFT // Being created
  REGISTRATION // Open for registration
  SEEDING // Registration closed, organizer is seeding
  IN_PROGRESS // Bracket generated, matches ongoing
  COMPLETED // All matches finished
  CANCELLED
}

model Tournament {
  id                String           @id @default(cuid())
  name              String
  description       String?          @db.Text
  gameId            String // Reference to Game model
  format            TournamentFormat
  status            TournamentStatus @default(DRAFT)
  maxTeams          Int
  startDate         DateTime
  endDate           DateTime?
  registrationStart DateTime
  registrationEnd   DateTime
  rules             String?          @db.Text
  prizePool         String? // Text field for flexibility (e.g., "$1000" or "Trophy + $500")
  banner            String? // URL to tournament banner image
  organizerId       String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  game          Game                     @relation(fields: [gameId], references: [id])
  organizer     User                     @relation("TournamentOrganizer", fields: [organizerId], references: [id])
  registrations TournamentRegistration[]
  brackets      Bracket[]
  matches       Match[]

  @@index([organizerId])
  @@index([status])
  @@index([gameId])
  @@index([startDate])
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model TournamentRegistration {
  id           String             @id @default(cuid())
  tournamentId String
  teamId       String
  status       RegistrationStatus @default(PENDING)
  seed         Int? // Assigned seed number (1, 2, 3, etc.)
  registeredAt DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@index([teamId])
  @@index([status])
}

// ============================================
// Bracket & Match System
// ============================================

enum BracketType {
  MAIN // For single elimination or round robin
  WINNERS // For double elimination
  LOSERS // For double elimination
  GRAND_FINAL // For double elimination grand final
}

model Bracket {
  id           String      @id @default(cuid())
  tournamentId String
  type         BracketType @default(MAIN)
  round        Int // Round number (1, 2, 3, etc.)
  createdAt    DateTime    @default(now())

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches    Match[]

  @@index([tournamentId])
}

enum MatchStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

model Match {
  id                String      @id @default(cuid())
  tournamentId      String
  bracketId         String
  homeTeamId        String
  awayTeamId        String
  homeScore         Int?
  awayScore         Int?
  status            MatchStatus @default(PENDING)
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  winnerTeamId      String?
  bestOf            Int         @default(1) // Best of 1, 3, 5, etc.
  nextMatchId       String? // ID of the match the winner advances to
  nextMatchSlot     String? // "home" or "away" - which slot in next match
  resultSubmittedBy String? // User who submitted the result
  disputeReason     String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  bracket         Bracket    @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  homeTeam        Team       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        Team       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winner          Team?      @relation("MatchWinner", fields: [winnerTeamId], references: [id])
  nextMatch       Match?     @relation("MatchProgression", fields: [nextMatchId], references: [id], onDelete: SetNull)
  previousMatches Match[]    @relation("MatchProgression")
  resultSubmitter User?      @relation("MatchResultSubmitter", fields: [resultSubmittedBy], references: [id])

  @@index([tournamentId])
  @@index([bracketId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([winnerTeamId])
  @@index([status])
}

// ============================================
// Notification System
// ============================================

enum NotificationType {
  MATCH_STARTING
  MATCH_RESULT
  REGISTRATION_APPROVED
  REGISTRATION_REJECTED
  TOURNAMENT_STARTING
  TOURNAMENT_CANCELLED
  TEAM_INVITATION
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String? // URL to relevant page
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}
